{
  "name": "online-store-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=../prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema=../prisma/schema.prisma",
    "prisma:seed": "node src/prisma/seed.js",
    "setup": "prisma generate --schema=../prisma/schema.prisma && prisma db push --schema=../prisma/schema.prisma && node src/prisma/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm test && npm run prisma:validate",
    "ci:full": "npm run ci && cd ../client && npm run build && npm test",
    "ci:e2e": "cd ../client && npm run build && npx playwright test"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "stripe": "^17.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  }
}
